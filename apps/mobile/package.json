{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:ci": "CI=1 expo start --port 8082",
    "dev:ios": "expo start --dev-client --port 8082",
    "dev:reset": "expo start --dev-client --port 8082 --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:sim": "expo run:ios -d \"iPhone 17 Pro\" -p 8082",
    "web": "expo start --web",
    "eas:build:ios": "eas build --platform ios",
    "eas:build:android": "eas build --platform android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~55.0.5",
    "expo-dev-client": "~55.0.16",
    "expo-speech-recognition": "^3.1.1",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
