{
  "expo": {
    "name": "PlusDo",
    "slug": "plusdo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iris.plusdo",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "允许 PlusDo 使用系统语音识别，把你的语音直接转成文字。",
        "NSMicrophoneUsageDescription": "允许 PlusDo 使用麦克风，把你的语音直接转成待办。"
      },
      "appleTeamId": "U9N9YK24BN"
    },
    "android": {
      "package": "com.iris.plusdo",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "允许 PlusDo 使用麦克风，把你的语音直接转成待办。",
          "speechRecognitionPermission": "允许 PlusDo 使用系统语音识别，把你的语音直接转成文字。"
        }
      ]
    ]
  }
}
